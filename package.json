{
  "name": "@hsml-lab/playground",
  "version": "0.0.0",
  "private": true,
  "description": "HSML Playground — Write HSML, see compiled HTML in real-time",
  "keywords": [
    "hsml",
    "html",
    "playground",
    "preprocessor"
  ],
  "bugs": "https://github.com/hsml-lab/playground/issues",
  "license": "MIT",
  "author": {
    "name": "Christopher Quadflieg",
    "email": "chrissi92@hotmail.de",
    "url": "https://github.com/Shinigami92"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/hsml-lab/playground.git"
  },
  "funding": [
    {
      "type": "github",
      "url": "https://github.com/Shinigami92"
    },
    {
      "type": "paypal",
      "url": "https://www.paypal.com/donate?hosted_button_id=L7GY729FBKTZY"
    }
  ],
  "type": "module",
  "scripts": {
    "clean": "git clean -fdx --exclude .claude",
    "dev": "vite",
    "build": "vue-tsc --noEmit && vite build",
    "preview": "vite preview",
    "format": "oxfmt .",
    "format:check": "oxfmt --check .",
    "lint": "oxlint",
    "ts-check": "vue-tsc --noEmit",
    "test:e2e": "playwright test",
    "preflight": "pnpm install && pnpm exec playwright install chromium && run-s format lint ts-check build test:e2e"
  },
  "dependencies": {
    "@codemirror/lang-html": "6.4.11",
    "@codemirror/language": "6.12.3",
    "@codemirror/lint": "6.9.5",
    "@codemirror/state": "6.6.0",
    "@codemirror/theme-one-dark": "6.1.3",
    "@codemirror/view": "6.41.0",
    "@vueuse/core": "14.2.1",
    "codemirror": "6.0.2",
    "hsml": "0.7.1",
    "lz-string": "1.5.0",
    "reka-ui": "2.9.5",
    "vue": "3.5.32"
  },
  "devDependencies": {
    "@iconify-json/lucide": "1.2.102",
    "@iconify/tailwind4": "1.2.3",
    "@playwright/test": "1.59.1",
    "@tailwindcss/vite": "4.2.2",
    "@types/node": "25.6.0",
    "@vitejs/plugin-vue": "6.0.5",
    "npm-run-all2": "8.0.4",
    "oxfmt": "0.44.0",
    "oxlint": "1.59.0",
    "tailwindcss": "4.2.2",
    "typescript": "6.0.2",
    "vite": "8.0.8",
    "vite-plugin-vue-hsml": "0.6.0",
    "vite-plugin-wasm": "3.6.0",
    "vue-tsc": "3.2.6"
  },
  "engines": {
    "node": ">=24.0.0"
  },
  "packageManager": "pnpm@10.33.0"
}
